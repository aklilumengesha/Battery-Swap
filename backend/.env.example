# Django core
SECRET_KEY=your-secret-key-here-replace-this
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database — PostgreSQL
DATABASE_URL=postgres://postgres:postgres@localhost:5432/batteryswap

# Redis — used by Celery (broker) and Django cache
REDIS_URL=redis://localhost:6379/0

# Email — use console backend for development
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@batteryswap.com

# Production only
SECURE_SSL_REDIRECT=False
